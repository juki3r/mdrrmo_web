{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "routes":[
    {
      "src" : "/(.*)",
      "dest": "https://ajcpisonet.com",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "headers":{
        "Access-Control-Allow-Origin": "*"
      }
    }
  ]
}